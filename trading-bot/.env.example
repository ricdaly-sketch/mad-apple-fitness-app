# Polymarket API credentials
# Get these from polymarket.com -> Settings -> API Keys
POLY_API_KEY=your_api_key_here
POLY_WALLET_ADDRESS=your_wallet_address_here

# Your wallet private key (used to sign live orders)
# Only needed for --live mode. Never share this.
PRIVATE_KEY=your_ethereum_private_key_here

# Mode: paper | live
TRADING_MODE=paper
